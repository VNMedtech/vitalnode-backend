// Medical Equipment Marketplace — Production Prisma Schema
// Source of truth: DATABASE_DESIGN.md, PRISMA_SCHEMA_GENERATION.md

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  ADMIN
  BUYER
  SELLER
  DELIVERY_PARTNER
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum BuyerType {
  DOCTOR
  HOSPITAL
}

enum SellerApprovalStatus {
  PENDING_APPROVAL
  ACTIVE
  REJECTED
  DISABLED
}

enum ProductStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  DISABLED
  OUT_OF_STOCK
}

enum InventoryMovementType {
  MANUAL_INCREASE
  MANUAL_DECREASE
  MANUAL_ADJUSTMENT
  ORDER_DEDUCTION
  ORDER_RESTORE
  ORDER_CANCELLATION
  REFUND_RESTORATION
  SYSTEM_CORRECTION
}

enum OrderStatus {
  PENDING_PAYMENT
  PAYMENT_FAILED
  PLACED
  ASSIGNED_DELIVERY_PARTNER
  PROCESSING
  OUT_FOR_DELIVERY
  DELIVERED
  PENDING_SETTLEMENT
  SETTLED
  DELIVERY_FAILED
  CANCELLED
  REFUNDED
}

enum SettlementBatchStatus {
  PENDING
  DISBURSED
}

enum ProofType {
  HANDOVER
  DELIVERY
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum RefundStatus {
  NOT_APPLICABLE
  PENDING
  SUCCESS
  FAILED
}

enum IdempotencyKeyStatus {
  PROCESSING
  COMPLETED
  FAILED
}

enum UploadCategory {
  IMAGE
  DOCUMENT
}

enum UploadStatus {
  UPLOADING
  UPLOADED
  FAILED
}

enum UploadType {
  PRODUCT_IMAGE
  PRODUCT_DOCUMENT
  HANDOVER_PROOF
  DELIVERY_PROOF
  PROFILE_IMAGE
}

enum ReviewStatus {
  ACTIVE
  DISABLED
}

// =============================================================================
// USER DOMAIN
// =============================================================================

model User {
  id                 String     @id @default(uuid())
  email              String     @unique
  passwordHash       String
  role               UserRole
  status             UserStatus
  mustChangePassword Boolean    @default(false)
  firstName          String
  lastName           String
  phoneNumber        String?    @unique
  profileImage       String?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  deletedAt          DateTime?

  buyerProfile           BuyerProfile?
  sellerProfile          SellerProfile?
  deliveryPartnerProfile DeliveryPartnerProfile?
  notifications          Notification[]
  auditLogs              AuditLog[]              @relation("AuditLogActor")
  inventoryMovements     InventoryMovement[]     @relation("InventoryMovementActor")
  idempotencyKeys        IdempotencyKey[]        @relation("IdempotencyKeyActor")
  uploadedOrderProofs    OrderProof[]            @relation("OrderProofUploader")
  fileUploads            FileUpload[]
  authSessions           AuthSession[]
  passwordResetTokens    PasswordResetToken[]
  createdSettlementBatches SettlementBatch[]    @relation("SettlementBatchCreator")

  @@index([role])
  @@index([status])
}

// =============================================================================
// PROFILE DOMAIN
// =============================================================================

model BuyerProfile {
  id        String    @id @default(uuid())
  userId    String    @unique
  buyerType BuyerType
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Restrict)
  addresses Address[]
  cart      Cart?
  orders    Order[]
  reviews   ProductReview[]
}

model SellerProfile {
  id                   String               @id @default(uuid())
  userId               String               @unique
  businessName         String
  contactPerson        String
  addressLine1         String
  addressLine2         String?
  city                 String
  state                String
  country              String
  postalCode           String
  latitude             Decimal?             @db.Decimal(10, 7)
  longitude            Decimal?             @db.Decimal(10, 7)
  approvalStatus       SellerApprovalStatus
  commissionPercentage Decimal?             @db.Decimal(5, 2)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  user               User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  documents          SellerDocument[]
  products           Product[]
  orders             Order[]
  settlementBatches  SettlementBatch[]
}

model SellerDocument {
  id        String   @id @default(uuid())
  sellerId  String
  fileUrl   String
  fileType  String
  createdAt DateTime @default(now())

  seller SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([sellerId])
}

model DeliveryPartnerProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  country      String
  postalCode   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Restrict)
  orders Order[]
}

// =============================================================================
// ADDRESS DOMAIN
// =============================================================================

model Address {
  id           String   @id @default(uuid())
  buyerId      String
  name         String
  phone        String
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  country      String
  postalCode   String
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  buyer BuyerProfile @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  @@index([buyerId])
}

// =============================================================================
// CATEGORY DOMAIN
// =============================================================================

model Category {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  products Product[]
}

// =============================================================================
// PRODUCT DOMAIN
// =============================================================================

model Product {
  id             String        @id @default(uuid())
  sellerId       String
  categoryId     String
  productName    String
  brand          String
  model          String
  productType    String
  color          String?
  weight         Decimal?      @db.Decimal(10, 2)
  length         Decimal?      @db.Decimal(10, 2)
  warrantyPeriod Int?
  returnTime     Int?
  deliveryTime   Int?
  pricing        Decimal       @db.Decimal(12, 2)
  moq            Int
  description    String
  details        String?
  specifications Json?
  status         ProductStatus
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  seller         SellerProfile       @relation(fields: [sellerId], references: [id], onDelete: Restrict)
  category       Category            @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  media          ProductMedia[]
  documents      ProductDocument[]
  inventory      Inventory?
  inventoryMoves InventoryMovement[]
  cartItems      CartItem[]
  orderItems     OrderItem[]
  reviews        ProductReview[]

  @@index([sellerId])
  @@index([categoryId])
  @@index([status])
  @@index([brand])
  @@index([model])
  @@index([productName])
}

model ProductMedia {
  id           String   @id @default(uuid())
  productId    String
  fileUploadId String?  @unique
  fileUrl      String
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  fileUpload FileUpload? @relation("ProductMediaUpload", fields: [fileUploadId], references: [id], onDelete: Restrict)

  @@index([productId])
}

model ProductDocument {
  id           String   @id @default(uuid())
  productId    String
  fileUploadId String?  @unique
  fileUrl      String
  documentType String
  createdAt    DateTime @default(now())

  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  fileUpload FileUpload? @relation("ProductDocumentUpload", fields: [fileUploadId], references: [id], onDelete: Restrict)

  @@index([productId])
}

// =============================================================================
// INVENTORY DOMAIN
// =============================================================================

model Inventory {
  id                String   @id @default(uuid())
  productId         String   @unique
  availableQuantity Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
}

model InventoryMovement {
  id              String                @id @default(uuid())
  productId       String
  actorUserId     String?
  quantityBefore  Int                   @default(0)
  quantityAfter   Int                   @default(0)
  quantityChanged Int                   @default(0)
  quantity        Int
  movementType    InventoryMovementType
  referenceId     String?
  reason          String?
  notes           String?
  createdAt       DateTime              @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  actor   User?   @relation("InventoryMovementActor", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@unique([referenceId, productId, movementType], map: "InventoryMovement_order_dedupe_key")
  @@index([productId])
  @@index([movementType])
  @@index([referenceId])
  @@index([actorUserId])
}

// =============================================================================
// REVIEW DOMAIN
// =============================================================================

model ProductReview {
  id        String       @id @default(uuid())
  productId String
  buyerId   String
  rating    Int
  title     String
  comment   String
  status    ReviewStatus @default(ACTIVE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  product Product      @relation(fields: [productId], references: [id], onDelete: Restrict)
  buyer   BuyerProfile @relation(fields: [buyerId], references: [id], onDelete: Restrict)

  @@unique([productId, buyerId])
  @@index([productId])
  @@index([buyerId])
  @@index([status])
}

// =============================================================================
// CART DOMAIN
// =============================================================================

model Cart {
  id        String   @id @default(uuid())
  buyerId   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyer BuyerProfile @relation(fields: [buyerId], references: [id], onDelete: Restrict)
  items CartItem[]
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String
  productId String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
}

// =============================================================================
// ORDER DOMAIN
// =============================================================================

model Order {
  id                           String       @id @default(uuid())
  orderNumber                  String       @unique
  buyerId                      String
  sellerId                     String
  deliveryPartnerId            String?
  shippingAddressSnapshot      Json
  orderStatus                  OrderStatus
  subtotal                     Decimal      @db.Decimal(12, 2)
  totalAmount                  Decimal      @db.Decimal(12, 2)
  deliveredAt                  DateTime?
  grossAmount                  Decimal?     @db.Decimal(12, 2)
  commissionPercentageSnapshot Decimal?     @db.Decimal(5, 2)
  commissionAmount             Decimal?     @db.Decimal(12, 2)
  sellerReceivableAmount       Decimal?     @db.Decimal(12, 2)
  settlementBatchId            String?
  placedAt                     DateTime?
  createdAt                    DateTime     @default(now())
  updatedAt                    DateTime     @updatedAt

  buyer           BuyerProfile            @relation(fields: [buyerId], references: [id], onDelete: Restrict)
  seller          SellerProfile           @relation(fields: [sellerId], references: [id], onDelete: Restrict)
  deliveryPartner DeliveryPartnerProfile? @relation(fields: [deliveryPartnerId], references: [id], onDelete: Restrict)
  settlementBatch SettlementBatch?        @relation(fields: [settlementBatchId], references: [id], onDelete: Restrict)
  items           OrderItem[]
  payment         Payment?
  proofs          OrderProof[]

  @@index([buyerId])
  @@index([sellerId])
  @@index([deliveryPartnerId])
  @@index([orderStatus])
  @@index([placedAt])
  @@index([settlementBatchId])
  @@index([deliveredAt])
}

model OrderItem {
  id              String   @id @default(uuid())
  orderId         String
  productId       String
  productSnapshot Json
  quantity        Int
  unitPrice       Decimal  @db.Decimal(12, 2)
  totalPrice      Decimal  @db.Decimal(12, 2)
  createdAt       DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Restrict)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

model OrderProof {
  id           String    @id @default(uuid())
  orderId      String
  proofType    ProofType
  fileUploadId String?   @unique
  fileUrl      String
  uploadedBy   String
  createdAt    DateTime  @default(now())

  order      Order       @relation(fields: [orderId], references: [id], onDelete: Restrict)
  uploader   User        @relation("OrderProofUploader", fields: [uploadedBy], references: [id], onDelete: Restrict)
  fileUpload FileUpload? @relation("OrderProofUpload", fields: [fileUploadId], references: [id], onDelete: Restrict)

  @@unique([orderId, proofType])
  @@index([orderId])
  @@index([uploadedBy])
  @@index([proofType])
}

// =============================================================================
// SETTLEMENT DOMAIN
// =============================================================================

model SettlementBatch {
  id                String                @id @default(uuid())
  sellerId          String
  batchNumber       String                @unique
  status            SettlementBatchStatus
  grossAmount       Decimal               @db.Decimal(12, 2)
  commissionAmount  Decimal               @db.Decimal(12, 2)
  netAmount         Decimal               @db.Decimal(12, 2)
  paymentReference  String?
  remarks           String?
  disbursedAt       DateTime?
  createdByAdminId  String
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  seller  SellerProfile @relation(fields: [sellerId], references: [id], onDelete: Restrict)
  creator User          @relation("SettlementBatchCreator", fields: [createdByAdminId], references: [id], onDelete: Restrict)
  orders  Order[]

  @@index([sellerId])
  @@index([status])
  @@index([createdAt])
  @@index([disbursedAt])
  @@index([createdByAdminId])
}

// =============================================================================
// PAYMENT DOMAIN
// =============================================================================

model Payment {
  id                String        @id @default(uuid())
  orderId           String        @unique
  razorpayOrderId   String        @unique
  razorpayPaymentId String?       @unique
  amount            Decimal       @db.Decimal(12, 2)
  paymentStatus     PaymentStatus
  refundStatus      RefundStatus  @default(NOT_APPLICABLE)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([paymentStatus])
}

model IdempotencyKey {
  id           String               @id @default(uuid())
  key          String
  actorUserId  String
  route        String
  requestHash  String?
  responseBody Json?
  status       IdempotencyKeyStatus
  createdAt    DateTime             @default(now())
  expiresAt    DateTime

  actor User @relation("IdempotencyKeyActor", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@unique([actorUserId, key, route])
  @@index([expiresAt])
}

model WebhookEvent {
  id          String    @id @default(uuid())
  provider    String
  eventId     String
  eventType   String
  payload     Json
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([provider, eventId])
  @@index([eventType])
  @@index([createdAt])
}

// =============================================================================
// NOTIFICATION DOMAIN
// =============================================================================

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([isRead])
  @@index([type])
}

// =============================================================================
// AUDIT DOMAIN
// =============================================================================

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  createdAt   DateTime @default(now())

  actor User @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([actorUserId])
  @@index([entityType])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])
}

// =============================================================================
// AUTH DOMAIN
// =============================================================================

model AuthSession {
  id               String    @id @default(uuid())
  userId           String
  refreshTokenHash String
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  // Operational metadata (optional)
  ipAddress String?
  userAgent String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([usedAt])
}

// =============================================================================
// UPLOAD DOMAIN
// =============================================================================

model FileUpload {
  id           String         @id @default(uuid())
  userId       String
  uploadType   UploadType     @default(PRODUCT_IMAGE)
  category     UploadCategory
  status       UploadStatus   @default(UPLOADING)
  s3Key        String         @unique
  bucket       String
  mimeType     String
  originalName String
  size         Int
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  productMedia    ProductMedia?    @relation("ProductMediaUpload")
  productDocument ProductDocument? @relation("ProductDocumentUpload")
  orderProof      OrderProof?      @relation("OrderProofUpload")

  @@index([userId])
  @@index([uploadType])
  @@index([category])
  @@index([status])
}
