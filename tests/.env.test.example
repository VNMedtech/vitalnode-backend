NODE_ENV=test
DATABASE_URL=postgresql://admin:postgres@localhost:5432/medical_test
JWT_SECRET=test-access-token-secret-min-32-chars!!
JWT_REFRESH_SECRET=test-refresh-token-secret-min-32-chars!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=8
PASSWORD_RESET_TOKEN_EXPIRES_IN_MINUTES=30
AUTH_RATE_LIMIT_MAX=10000
RATE_LIMIT_MAX=10000
LOG_LEVEL=silent
PORT=5011
RAZORPAY_KEY_ID=rzp_test_mock_key_id
RAZORPAY_KEY_SECRET=test_razorpay_key_secret_32chars!!
RAZORPAY_WEBHOOK_SECRET=test_webhook_secret_32chars_ok!!
SYSTEM_ACTOR_USER_ID=00000000-0000-4000-8000-000000000099

# Optional — only if testing real AWS (most suites mock S3/SES)
# AWS_S3_REGION=ap-south-1
# AWS_S3_BUCKET_NAME=test-bucket
# AWS_S3_ACCESS_KEY_ID=
# AWS_S3_SECRET_ACCESS_KEY=
# AWS_SES_REGION=ap-south-1
# AWS_SES_ACCESS_KEY_ID=
# AWS_SES_SECRET_ACCESS_KEY=
# SES_FROM_EMAIL=test@example.com
