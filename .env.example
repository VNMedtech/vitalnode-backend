DATABASE_URL=postgresql://user:pass@localhost:5432/medical_local
JWT_SECRET=change-me-min-32-characters-long!!
JWT_REFRESH_SECRET=change-me-min-32-characters-long!!
PORT=5010
NODE_ENV=development

# S3 (file uploads) — use a dedicated IAM user with S3 permissions only
AWS_S3_REGION=ap-south-1
AWS_S3_BUCKET_NAME=your-bucket-name
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
AWS_S3_SIGNED_URL_EXPIRES_IN_SECONDS=3600

# SES (transactional email) — use a separate IAM user with SES permissions only
AWS_SES_REGION=ap-south-1
AWS_SES_ACCESS_KEY_ID=
AWS_SES_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=noreply@yourdomain.com
SES_FROM_NAME=Medical Equipment Marketplace
SES_REPLY_TO_EMAIL=support@yourdomain.com
WEB_APP_BASE_URL=http://localhost:5173

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
SYSTEM_ACTOR_USER_ID=
